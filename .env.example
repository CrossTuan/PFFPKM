DISCORD_TOKEN=your_discord_bot_token_here

# Optional: speed up slash command updates in one server while developing
AUTO_SYNC_COMMANDS=true
GUILD_ID=your_test_server_id
COMMAND_SCOPE=guild
CLEAN_OTHER_SCOPE=true

# Optional (recommended on Render free): persist players via MongoDB instead of local JSON file
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/?retryWrites=true&w=majority
# MONGODB_DB=pffpkm
# MONGODB_COLLECTION=players
